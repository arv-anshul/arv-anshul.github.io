---
import { Icon } from "astro-icon/components";
import Button from "@/components/starwind/button";
import { loadInfoData } from "@/lib/data-loaders/info";
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;

const infoData = await loadInfoData();
const copyrightYear = new Date().getFullYear();
const linkItems = [
  {
    url: "/resume",
    name: "Resume",
    icon: "lucide:scroll-text",
  },
  {
    url: "/rss.xml",
    name: "RSS Feed",
    icon: "lucide:rss",
  },
  ...infoData.socials.filter(
    (item) => !["Website", "IMDb", "Spotify"].includes(item.name)
  ),
];
---

<footer class={cn("bg-accent px-4 md:px-0 py-3 text-sm", className)}>
  <div
    class="flex flex-col-reverse gap-2 md:flex-row md:justify-between justify-center items-center w-full md:w-2/3 xl:w-3/5 mx-auto"
  >
    <div class="flex flex-col items-center md:items-start">
      <span>
        Copyright &copy; {copyrightYear}
        <span class="text-muted-foreground font-bold">Anshul Raj Verma</span>
      </span>
      <span>
        Made with
        <span class="animate-pulse text-red-500 text-lg align-middle">
          &hearts;
        </span>
      </span>
    </div>
    <div class="flex">
      {linkItems.map((item) => (
          <Button
            class="size-9 gap-0 transition-colors hover:text-muted-foreground"
            href={item.url}
            size="icon"
            target="_blank"
            title={item.name}
            variant="ghost"
          >
            <Icon name={item.icon} title={item.name} />
          </Button>
        ))}
    </div>
  </div>
</footer>
